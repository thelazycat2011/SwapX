{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"mac": "2.2081"
	},
	"id": "thelazycat2011.swapx",
	"name": "SwapX",
	"version": "v1.3.1",
	"developer": "thelazycat2011",
	"description": "Swapping level while nobody notice",
	"dependencies": {
		"hjfod.gmd-api": ">=1.5.0"
	},
	"resources": {
		"files": [
			"resources/*.ttf"
		]
	},
	"settings": {
		"toggle-menu": {
			"type": "keybind",
			"name": "SwapX menu Keybind",
			"default": "Ctrl+L",
			"migrate-from": "thelazycat2011.swapx/imgui-menu"
		},
		"swap-toggle": {
			"type": "keybind",
			"name": "Swap keybind",
			"default": "N",
			"migrate-from": "thelazycat2011.swapx/swap-toggle"
		},
		"level-folder": {
			"type": "folder",
			"name": "LevelDB",
			"default": "{gd_dir}/leveldb"
		},
		"rounding": {
			"type": "float",
			"name": "Menu rounding",
			"description": "Change how rounded is the menu UI component",
			"default": 0,
			"min": 0.0,
			"max": 16.0,
			"requires-restart": true
		}
	},
	"tags": ["gameplay", "offline", "cheat"]
}
